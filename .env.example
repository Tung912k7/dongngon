# Environment Variables for Đồng ngôn Project
# Copy this file to .env.local and fill in your actual values
# Do NOT commit .env.local or .env to version control

# ============================================================
# SUPABASE CONFIGURATION (Required)
# ============================================================

# Supabase project URL (public, safe to expose)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxx.supabase.co

# Supabase anonymous key (public, safe to expose)
# Used for client-side authentication and data access
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase service role key (PRIVATE - server-side only)
# Used for admin operations, never expose to client
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Alternative name (fallback if above not found)
SUPABASE_SERVICE_ROLE=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# SITE CONFIGURATION
# ============================================================

# Your production domain (for password reset emails, etc.)
NEXT_PUBLIC_SITE_URL=https://dongngon.vercel.app

# ============================================================
# POSTHOG ANALYTICS (Required)
# ============================================================

# PostHog API key (public, safe to expose)
NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxx

# PostHog API host
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ============================================================
# BUILD CONFIGURATION (Optional)
# ============================================================

# Enable bundle size analysis
# ANALYZE=true

# ============================================================
# ENVIRONMENT
# ============================================================

# Node environment (automatically set by Next.js, don't usually override)
# NODE_ENV=production

# ============================================================
# SETUP INSTRUCTIONS
# ============================================================
#
# 1. Copy this file: cp .env.example .env.local
#
# 2. Get Supabase credentials:
#    - Go to https://app.supabase.com
#    - Select your project
#    - Settings → API → Find the values above
#    - NEXT_PUBLIC_SUPABASE_URL: Copy from "URL"
#    - NEXT_PUBLIC_SUPABASE_ANON_KEY: Copy from "anon public"
#    - SUPABASE_SERVICE_ROLE_KEY: Copy from "service_role secret"
#
# 3. Get PostHog credentials:
#    - Go to https://posthog.com
#    - Project settings → API keys
#    - Copy your API key
#
# 4. Verify setup:
#    - npm install
#    - npm run dev
#    - Check browser console for errors
#    - Verify analytics events appear in PostHog
#
# ============================================================
# SECURITY NOTES
# ============================================================
#
# ✅ Safe to expose (public):
#    - NEXT_PUBLIC_SUPABASE_URL
#    - NEXT_PUBLIC_SUPABASE_ANON_KEY
#    - NEXT_PUBLIC_POSTHOG_KEY
#    - NEXT_PUBLIC_POSTHOG_HOST
#    - NEXT_PUBLIC_SITE_URL
#
# 🔒 PRIVATE - Never expose:
#    - SUPABASE_SERVICE_ROLE_KEY
#    - .env.local file
#    - Any keys in .env files (add *.env to .gitignore)
#
# ============================================================
# TROUBLESHOOTING
# ============================================================
#
# If auth fails:
#   - Check NEXT_PUBLIC_SUPABASE_URL is correct
#   - Verify NEXT_PUBLIC_SUPABASE_ANON_KEY has permissions
#   - Check browser console for CORS errors
#
# If password reset fails:
#   - Verify NEXT_PUBLIC_SITE_URL matches your domain
#   - Check email addresses in Supabase auth settings
#   - Verify SUPABASE_SERVICE_ROLE_KEY is correct
#
# If analytics doesn't track:
#   - Check NEXT_PUBLIC_POSTHOG_KEY is correct
#   - Verify PostHog API host is accessible
#   - Check browser console for JavaScript errors
#
# ============================================================
